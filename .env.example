# Optional: low-cost independent review pass using Gemini Flash-Lite.
# Recommended model as of July 2026: gemini-3.1-flash-lite.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# Optional: used by src/proofMcp.ts to create a real Composio session with hosted MCP.
COMPOSIO_API_KEY=

# Optional: use a search provider in a richer implementation.
TAVILY_API_KEY=
SERPER_API_KEY=

# Optional: deployment through Vercel CLI.
VERCEL_TOKEN=
