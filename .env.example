# Required only for live LLM-backed extraction. The repository includes a deterministic
# seeded research fallback so reviewers can run the pipeline without paid keys.
OPENAI_API_KEY=

# Optional: used by src/proofMcp.ts to create a real Composio session with hosted MCP.
COMPOSIO_API_KEY=

# Optional: use a search provider in a richer implementation.
TAVILY_API_KEY=
SERPER_API_KEY=

# Optional: deployment through Vercel CLI.
VERCEL_TOKEN=
